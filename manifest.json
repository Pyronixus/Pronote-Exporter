{
  "manifest_version": 3,
  "name": "PRONOTE EXPORTER",
  "version": "1.1.0",
  "description": "Exportez et visualisez vos notes et moyennes PRONOTE (JSON, CSV, Markdown).",
  "permissions": ["storage"],
  "action": {
    "default_popup": "src/html/popup.html",
    "default_icon": {
      "32": "src/assets/icons/icon32.png",
      "64": "src/assets/icons/icon64.png",
      "128": "src/assets/icons/icon128.png"
    }
  },
  "icons": {
    "32": "src/assets/icons/icon32.png",
    "64": "src/assets/icons/icon64.png",
    "128": "src/assets/icons/icon128.png"
  },
  "host_permissions": ["*://*.index-education.net/*", "*://*.pronote/*", "*://*.toutatice.fr/*"],
  "content_scripts": [{
    "matches": ["*://*.index-education.net/*", "*://*.pronote/*", "*://*.toutatice.fr/*"],
    "js": ["src/scripts/content.js"],
    "run_at": "document_start"
  }],
  "web_accessible_resources": [{
    "resources": ["src/scripts/inject.js"],
    "matches": ["<all_urls>"]
  }]
}